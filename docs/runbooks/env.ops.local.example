# Copier vers .env.ops.local et remplir (jamais committer — déjà couvert par .env*).
# Puis: node scripts/run-phase1-ops.mjs

# --- Supabase (obligatoire pour migrations) ---
# Connection string (Session mode) depuis Dashboard → Project Settings → Database
DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# OU access token compte (Dashboard → Account → Access Tokens)
# SUPABASE_ACCESS_TOKEN=sbp_...

# REST verify (optionnel si DATABASE_URL présent)
NEXT_PUBLIC_SUPABASE_URL=https://nimjmyiggqgvledgwffv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Railway WhatsApp (à coller aussi dans Railway Dashboard) ---
WHATSAPP_API_ENABLED=true
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_TEST_CLIENT_ID=

# --- Meta templates submit (mêmes creds) ---
# Utilise WHATSAPP_ACCESS_TOKEN + WHATSAPP_BUSINESS_ACCOUNT_ID

