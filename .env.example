# =============================================================================
# Loyala AI — Environment Variables (Production Template)
# =============================================================================
# NEVER commit real secrets. Copy to apps/web/.env.local (dev) or platform dashboards.
#
# Vercel (web):     Project Settings → Environment Variables  (project: loyala-ai-web)
# Railway (worker): Variables tab  (service: loyala-worker)
# Ops local:        .env.ops.local (gitignored) — see docs/runbooks/env.ops.local.example
# GitHub Actions:   Settings → Secrets and variables → Actions
# =============================================================================

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://fmagence.online
NEXT_PUBLIC_SITE_URL=https://fmagence.online

# WhatsApp demo booking on marketing site (Congo +242 — ex. 065719922 → wa.me/24265719922)
NEXT_PUBLIC_DEMO_WHATSAPP=065719922

# ─── Supabase (required — web + worker) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres (migrations / ops scripts only)
# postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
DATABASE_URL=

# Pooler (recommended for Windows/IPv4 — Session :5432 or Transaction :6543)
# SUPABASE_DB_POOLER_URL=postgresql://postgres.[project]:[password]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ─── Worker HTTP (Railway) ───────────────────────────────────────────────────
WORKER_PORT=3000
WORKER_URL=https://your-worker.up.railway.app
WORKER_API_SECRET=generate-32-char-random-secret

# ─── AI Platform (@loyala/core-ai) — primarily worker ─────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PRIMARY_PROVIDER=openai
AI_FALLBACK_PROVIDER=anthropic
AI_MAX_RETRIES=3
AI_CACHE_TTL_SECONDS=3600
AI_MAX_COST_USD=0.05
AI_ALLOW_MOCK=false

# ─── Inngest (worker — required in production) ─────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=false
# INNGEST_SERVE_ORIGIN=https://your-worker.up.railway.app

# ─── Rate limiting (Upstash — required multi-replica Vercel) ─────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_API_MAX=60
RATE_LIMIT_WINDOW_SEC=60

# ─── Email (Resend — optional web) ───────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=Loyala <noreply@fmagence.online>

# ─── WhatsApp Cloud API (worker — set WHATSAPP_API_ENABLED=true to activate) ─
WHATSAPP_API_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0
# Gated auto-send / pilots (optional)
WHATSAPP_TEST_CLIENT_ID=
WHATSAPP_TEST_PHONE=
# Campaign template overrides (optional — defaults to catalog loyala_* / hello_world)
WHATSAPP_CAMPAIGN_TEMPLATE_NAME=
WHATSAPP_CAMPAIGN_TEMPLATE_LANGUAGE=fr
WHATSAPP_CAMPAIGN_TEMPLATE_USE_NAME_VAR=false

# ─── Security ────────────────────────────────────────────────────────────────
INTERNAL_API_SECRET=optional-web-internal-calls

# CRM MVP: allow any org member to write clients (not only roles with clients:write).
# Set to false to enforce strict RBAC (org_viewer can read only).
CRM_MVP_CLIENTS_BYPASS=true

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
# BETTERSTACK_HEARTBEAT_URL=https://uptime.betterstack.com/api/v1/heartbeat/...

# ─── Billing (not wired yet) ─────────────────────────────────────────────────
# STRIPE_SECRET_KEY=

# ─── Vercel (auto-injected) ──────────────────────────────────────────────────
# VERCEL_ENV=production
# VERCEL_GIT_COMMIT_SHA=...
# VERCEL_URL=...

# ─── CI / GitHub Actions secrets (mirror Supabase vars) ─────────────────────
# SUPABASE_URL=              (same as NEXT_PUBLIC_SUPABASE_URL)
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ─── Feature flags (optional) ────────────────────────────────────────────────
# FEATURE_CAMPAIGNS_ENABLED=true
# FEATURE_WHATSAPP_ENABLED=false

# ─── Auth diagnostics (temporary — never enable in production) ───────────────
# Allowed only in local / Vercel preview. Production deployments ignore AUTH_DEBUG=1.
# AUTH_DEBUG=0
