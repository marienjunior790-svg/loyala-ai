# =============================================================================
# Loyala AI — Environment Variables (Production Template)
# =============================================================================
# NEVER commit real secrets. Copy to apps/web/.env.local (dev) or platform dashboards.
#
# Vercel (web):     Project Settings → Environment Variables
# Railway (worker): Variables tab
# GitHub Actions:   Settings → Secrets and variables → Actions
# =============================================================================

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://fmagence.online
NEXT_PUBLIC_SITE_URL=https://fmagence.online

# WhatsApp demo booking (Congo +242 — ex. 065719922 → wa.me/24265719922)
NEXT_PUBLIC_DEMO_WHATSAPP=065719922

# ─── Supabase (required) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres (migrations only — CI / local)
# postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
DATABASE_URL=

# Pooler (recommended prod — port 6543, transaction mode)
# SUPABASE_DB_POOLER_URL=postgresql://postgres.[project]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ─── Worker (Railway / Fly) ──────────────────────────────────────────────────
WORKER_PORT=3000
WORKER_URL=https://your-worker.up.railway.app
WORKER_API_SECRET=generate-32-char-random-secret

# ─── AI Platform (@loyala/core-ai) ─────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PRIMARY_PROVIDER=openai
AI_FALLBACK_PROVIDER=anthropic
AI_MAX_RETRIES=3
AI_CACHE_TTL_SECONDS=3600
AI_MAX_COST_USD=0.05
AI_ALLOW_MOCK=false

# ─── Inngest (worker — required in production) ─────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=false

# ─── Rate limiting (Upstash — required multi-replica prod) ───────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_API_MAX=60
RATE_LIMIT_WINDOW_SEC=60

# ─── Security ────────────────────────────────────────────────────────────────
INTERNAL_API_SECRET=optional-web-internal-calls

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
# BETTERSTACK_HEARTBEAT_URL=https://uptime.betterstack.com/api/v1/heartbeat/...

# ─── Vercel (auto-injected) ──────────────────────────────────────────────────
# VERCEL_ENV=production
# VERCEL_GIT_COMMIT_SHA=...
# VERCEL_URL=...

# ─── CI / GitHub Actions secrets (mirror Supabase vars) ─────────────────────
# SUPABASE_URL=              (same as NEXT_PUBLIC_SUPABASE_URL)
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ─── Feature flags (optional) ────────────────────────────────────────────────
# FEATURE_CAMPAIGNS_ENABLED=true
# FEATURE_WHATSAPP_ENABLED=false

# ─── Auth diagnostics (temporary — Vercel Function Logs) ─────────────────────
# Set to 1 during RSC/auth incident investigation; remove or set 0 after validation.
# AUTH_DEBUG=1
