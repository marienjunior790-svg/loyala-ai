# Loyala AI — environment template (never commit secrets)

NODE_ENV=development

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
WORKER_URL=http://localhost:3001
WORKER_API_SECRET=change-me-min-16-chars

# Worker / AI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PRIMARY_PROVIDER=openai
AI_FALLBACK_PROVIDER=anthropic
AI_ALLOW_MOCK=true
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=true

# WhatsApp (Meta)
WHATSAPP_API_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Billing — OpenPay Congo only (no Stripe)
BILLING_PROVIDER=openpay_cg
BILLING_ENABLED=false
OPENPAY_API_KEY=
OPENPAY_API_BASE=https://api.openpay-cg.com/v1
OPENPAY_WEBHOOK_SECRET=
# Optional when private docs provide a status path, e.g. /transaction/status/:id
OPENPAY_STATUS_PATH=

# Optional integrations
RESEND_API_KEY=
RESEND_FROM_EMAIL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
BETTERSTACK_HEARTBEAT_URL=
AUTH_DEBUG=0
NEXT_PUBLIC_DEMO_WHATSAPP=065719922
