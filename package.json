{
  "name": "loyala-ai",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=web",
    "dev:worker": "turbo dev --filter=worker",
    "lint": "turbo lint",
    "test": "vitest run",
    "test:rls": "vitest run packages/db/tests",
    "test:watch": "vitest",
    "typecheck": "turbo typecheck",
    "db:migrate": "node scripts/apply-migrations.mjs",
    "verify:prod": "node scripts/verify-production.mjs",
    "check:migrations": "node scripts/check-migrations.mjs"
  },
  "devDependencies": {
    "pg": "^8.13.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
